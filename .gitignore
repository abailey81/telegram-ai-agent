#uv.lock
#Pipfile.lock
#poetry.lock
#pdm.lock
.pdm.toml
.pdm-python
.pdm-build/

# ------------------------------------------------------------------------------
# Celery
# ------------------------------------------------------------------------------
celerybeat-schedule
celerybeat.pid

# SageMath
*.sage.py

# ------------------------------------------------------------------------------
