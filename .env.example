# Telegram API Credentials (Required - get from https://my.telegram.org/apps)
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef

# Session Management (Choose ONE)
# Option 1: File-based session (a .session file will be created)
TELEGRAM_SESSION_NAME=telegram_session

# Option 2: String-based session (recommended - generate with: uv run session_string_generator.py)
TELEGRAM_SESSION_STRING=your_session_string_here

# AI Gateway API Credentials (Required for CLI agent)
AI_GATEWAY_API_KEY=your_vercel_gateway_key

# Nia API Credentials (Optional - enables extended knowledge base search)
NIA_API_KEY=your_nia_key
NIA_CODEBASE_SOURCE=your_knowledge_source

# Anthropic API Key (Optional - enables image understanding via Claude Vision)
ANTHROPIC_API_KEY=your_anthropic_key
